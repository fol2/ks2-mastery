# Normalise line endings: all tracked text files use LF in the repo.
# Git will convert to the platform line ending on checkout only where a
# user opts in (core.autocrlf), and never in the committed blobs.
* text=auto eol=lf

# Binary assets should never be touched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
