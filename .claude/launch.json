{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Worker Dev (wrangler)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev"],
      "port": 8787
    },
    {
      "name": "Worker Dev (OAuth, local creds)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["./scripts/wrangler-oauth.mjs", "dev"],
      "port": 8787
    },
    {
      "name": "Worker Dev (remote bindings)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev", "--remote"],
      "port": 8787
    },
    {
      "name": "Worker Dev (tunnel, remote bindings)",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "wrangler",
        "dev",
        "--remote",
        "--var",
        "APP_ORIGIN:https://dev-ks2.eugnel.uk"
      ],
      "port": 8787
    },
    {
      "name": "Design Preview (static)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5500", "--bind", "127.0.0.1"],
      "port": 5500
    }
  ]
}
