# Capacity run artefacts: track latest-per-env snapshots and quarterly
# archives; ignore intermediate runs. See reports/capacity/.gitignore.
reports/capacity/*
!reports/capacity/.gitignore
!reports/capacity/latest-*.json
!reports/capacity/snapshots/
!reports/capacity/snapshots/**
!reports/capacity/configs/
!reports/capacity/configs/**
!reports/capacity/README.md

# Punctuation Phase 4 U8 browser journey artefacts (screenshots + logs).
# The specs write PNGs here per-step; never commit them — they can
# carry session/origin hints from the developer's browser profile.
tests/journeys/artifacts/
tests/journeys/*.log
